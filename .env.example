# Copy to .env.local and fill in real values (.env.local is gitignored).

# Admin backend login passcode.
ADMIN_PASSCODE=change-me

# HMAC key for signing the admin session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-hex-string

# Optional: SQLite path (defaults to ~/.act-app/act.db, kept outside OneDrive).
# ACT_DB_PATH=/custom/path/act.db

# Optional: shorten every section to N seconds for testing timeout/auto-submit.
# ACT_DURATION_OVERRIDE=120
